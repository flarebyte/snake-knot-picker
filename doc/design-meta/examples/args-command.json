{
  "version": "1",
  "commandPath": ["wash", "start"],
  "adminOnly": true,
  "flags": [
    {
      "kind": "boolean",
      "name": "extra-rinse"
    },
    {
      "kind": "string",
      "name": "mode",
      "schema": ["schema", "string", "--enum", "normal,delicate,whites"]
    },
    {
      "kind": "number",
      "name": "spin",
      "schema": ["schema", "number", "--int"]
    },
    {
      "kind": "tuple",
      "name": "range",
      "schemas": [
        ["schema", "number", "--tuple", "0", "--int"],
        ["schema", "number", "--tuple", "1", "--int"]
      ]
    },
    {
      "kind": "string",
      "name": "add",
      "repeatable": true,
      "schemas": [
        ["schema", "string", "--alpha"],
        ["schema", "repeatable", "--min-length", "1", "--max-length", "5"]
      ]
    },
    {
      "kind": "tuple",
      "name": "pair",
      "repeatable": true,
      "schemas": [
        ["schema", "string", "--tuple", "0", "--alpha"],
        ["schema", "string", "--tuple", "1", "--hex"],
        ["schema", "repeatable", "--min-length", "1", "--max-length", "5"]
      ]
    },
    {
      "kind": "number",
      "name": "dose",
      "repeatable": true,
      "schemas": [
        ["schema", "number", "--int"],
        ["schema", "repeatable", "--min-length", "1", "--max-length", "3"]
      ]
    },
    {
      "kind": "string",
      "name": "report",
      "schema": ["schema", "string", "--uri"]
    },
    {
      "kind": "string",
      "name": "accent",
      "schema": ["schema", "string", "--color"]
    },
    {
      "kind": "string",
      "name": "contact-email",
      "schema": ["schema", "string", "--email"]
    },
    {
      "kind": "string",
      "name": "release-date-time",
      "schema": ["schema", "string", "--datetime"]
    },
    {
      "kind": "string",
      "name": "retry-duration",
      "schema": ["schema", "string", "--duration"]
    },
    {
      "kind": "string",
      "name": "checksum",
      "schema": ["schema", "string", "--base64"]
    },
    {
      "kind": "string",
      "name": "starts-with",
      "schema": ["schema", "string", "--starts-with", "wash-"]
    },
    {
      "kind": "string",
      "name": "codepoints",
      "schema": ["schema", "string", "--codepoint-range", "U+3040", "U+309F"]
    },
    {
      "kind": "string",
      "name": "hex",
      "schema": ["schema", "string", "--hex"]
    },
    {
      "kind": "string",
      "name": "temp",
      "schema": ["schema", "string", "--enum", "cold,warm,hot"]
    },
    {
      "kind": "string",
      "name": "due-date",
      "schema": ["schema", "string", "--date"]
    },
    {
      "kind": "string",
      "name": "enabled",
      "schema": ["schema", "string", "--boolean"]
    },
    {
      "kind": "string",
      "name": "alarm-time",
      "schema": ["schema", "string", "--time"]
    }
  ]
}
