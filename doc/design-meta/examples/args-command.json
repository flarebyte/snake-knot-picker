{
  "version": "1",
  "commandPath": ["wash", "start"],
  "adminOnly": true,
  "flags": [
    {
      "kind": "boolean",
      "name": "extra-rinse"
    },
    {
      "kind": "string",
      "name": "mode",
      "schema": ["schema", "string", "--enum", "normal,delicate,whites"]
    },
    {
      "kind": "number",
      "name": "spin",
      "schema": ["schema", "number", "--int"]
    },
    {
      "kind": "tuple",
      "name": "range",
      "schemas": [
        ["schema", "number", "--tuple", "0", "--int"],
        ["schema", "number", "--tuple", "1", "--int"]
      ]
    },
    {
      "kind": "string",
      "name": "add",
      "repeatable": true,
      "schema": ["schema", "string", "--alpha"]
    },
    {
      "kind": "tuple",
      "name": "pair",
      "repeatable": true,
      "schemas": [
        [
          ["schema", "string", "--alpha"],
          ["schema", "string", "--hex"]
        ]
      ]
    },
    {
      "kind": "string",
      "name": "report",
      "schema": ["schema", "string", "--uri"]
    },
    {
      "kind": "string",
      "name": "hex",
      "schema": ["schema", "string", "--hex"]
    },
    {
      "kind": "string",
      "name": "temp",
      "schema": ["schema", "string", "--enum", "cold,warm,hot"]
    },
    {
      "kind": "string",
      "name": "due-date",
      "schema": ["schema", "string", "--date"]
    },
    {
      "kind": "string",
      "name": "alarm-time",
      "schema": ["schema", "string", "--time"]
    }
  ]
}
