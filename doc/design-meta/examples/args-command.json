{
  "version": "1",
  "commandPath": ["wash", "start"],
  "adminOnly": true,
  "flags": [
    {
      "kind": "boolean",
      "name": "extra-rinse",
      "schema": ["schema", "boolean"]
    },
    {
      "kind": "string",
      "name": "mode",
      "schema": ["schema", "string", "--enum", "normal,delicate,whites", "--required"]
    },
    {
      "kind": "number",
      "name": "spin",
      "schema": ["schema", "number", "--int", "--required"]
    },
    {
      "kind": "tuple",
      "name": "range",
      "schema": [
        "schema",
        "number",
        "--tuple",
        "0",
        "--int",
        "--tuple",
        "1",
        "--int",
        "--required"
      ]
    },
    {
      "kind": "string",
      "name": "add",
      "schema": ["schema", "string", "--alpha"],
      "schemas": [
        ["schema", "repeatable", "--min-length", "1", "--max-length", "5"]
      ]
    },
    {
      "kind": "tuple",
      "name": "pair",
      "schema": ["schema", "tuple", "--tuple", "0", "--alpha", "--tuple", "1", "--hex"],
      "schemas": [
        ["schema", "repeatable", "--min-length", "1", "--max-length", "5"]
      ]
    },
    {
      "kind": "number",
      "name": "dose",
      "schema": ["schema", "number", "--int"],
      "schemas": [
        ["schema", "repeatable", "--min-length", "1", "--max-length", "3"]
      ]
    },
    {
      "kind": "string",
      "name": "report",
      "schema": ["schema", "string", "--uri", "--required"]
    },
    {
      "kind": "string",
      "name": "accent",
      "schema": ["schema", "string", "--color"]
    },
    {
      "kind": "string",
      "name": "postal-code",
      "schema": ["custom", "postal-code", "--country", "US", "--required"]
    },
    {
      "kind": "string",
      "name": "contact-email",
      "schema": ["schema", "string", "--email"]
    },
    {
      "kind": "string",
      "name": "release-date-time",
      "schema": ["schema", "string", "--datetime"]
    },
    {
      "kind": "string",
      "name": "retry-duration",
      "schema": ["schema", "string", "--duration"]
    },
    {
      "kind": "string",
      "name": "checksum",
      "schema": ["schema", "string", "--base64"]
    },
    {
      "kind": "string",
      "name": "starts-with",
      "schema": ["schema", "string", "--starts-with", "wash-"]
    },
    {
      "kind": "string",
      "name": "codepoints",
      "schema": ["schema", "string", "--codepoint-range", "U+3040", "U+309F"]
    },
    {
      "kind": "string",
      "name": "hex",
      "schema": ["schema", "string", "--hex"]
    },
    {
      "kind": "string",
      "name": "temp",
      "schema": ["schema", "string", "--enum", "cold,warm,hot", "--required"]
    },
    {
      "kind": "string",
      "name": "due-date",
      "schema": ["schema", "string", "--date", "--required"]
    },
    {
      "kind": "string",
      "name": "enabled",
      "schema": ["schema", "string", "--boolean"]
    },
    {
      "kind": "string",
      "name": "alarm-time",
      "schema": ["schema", "string", "--time", "--required"]
    }
  ]
}
